{
  "name": "tumpline",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "eleventy && tailwindcss -i ./src/assets/css/site.css -o ./_site/assets/css/site.css",
    "dev": "concurrently \"eleventy --serve\" \"tailwindcss -i ./src/assets/css/site.css -o ./_site/assets/css/site.css --watch\"",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && wrangler dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@tailwindcss/cli": "^4.3.1",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "wrangler": "^4.100.0"
  }
}
