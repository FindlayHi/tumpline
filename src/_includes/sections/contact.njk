<section id="contact" class="border-t border-line bg-band">
  <div class="max-w-[1180px] mx-auto px-8 py-[100px]" style="display:grid;grid-template-columns:1fr 1.05fr;gap:60px;align-items:start;">
    <div>
      <div class="font-mono text-xs font-medium tracking-[.2em] uppercase text-accent mb-4">Get in touch</div>
      <h2 class="font-serif font-semibold leading-[1.08] tracking-[-0.012em] m-0 mb-[18px]" style="font-size:clamp(30px,3.6vw,46px);">Let's see if we can help.</h2>
      <p class="text-lg leading-[1.62] text-muted m-0 mb-[30px] max-w-[30em]">Book a free 30-minute consult. Tell us a little about your situation and we'll do some homework before we talk — so the call is useful from minute one.</p>
      <div class="flex flex-col gap-4">
        {% for point in site.contactPoints %}
          <div class="flex gap-[13px] items-start">
            <span class="mt-0.5 text-accent font-bold">—</span>
            <span class="text-base leading-[1.5] text-ink">{{ point }}</span>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="bg-paper border border-line rounded-[18px] p-[34px]" style="box-shadow:0 24px 60px -36px rgba(0,0,0,.5);">
      <div data-form-wrapper>
        <form id="consult-form" action="https://formspree.io/f/YOUR_FORM_ID" method="post" novalidate>
          <div class="grid grid-cols-2 gap-[18px] mb-[18px]">
            <div>
              <label class="block text-[13px] font-semibold mb-[7px]">Name <span class="text-accent">*</span></label>
              <input name="name" id="f-name" required aria-required="true" type="text" placeholder="Jordan Lee" class="form-field">
              <div class="field-error" data-error-for="name" hidden></div>
            </div>
            <div>
              <label class="block text-[13px] font-semibold mb-[7px]">Company</label>
              <input name="company" id="f-company" type="text" placeholder="Acme Co." class="form-field">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-[18px] mb-[18px]">
            <div>
              <label class="block text-[13px] font-semibold mb-[7px]">Email <span class="text-accent">*</span></label>
              <input name="email" id="f-email" required aria-required="true" type="email" placeholder="you@company.com" class="form-field">
              <div class="field-error" data-error-for="email" hidden></div>
            </div>
            <div>
              <label class="block text-[13px] font-semibold mb-[7px]">Team size</label>
              <select name="teamSize" id="f-teamSize" class="form-field">
                <option value="">Select…</option>
                {% for size in site.teamSizes %}
                  <option value="{{ size }}">{{ size }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="mb-[22px]">
            <label class="block text-[13px] font-semibold mb-[7px]">What's slowing you down? <span class="text-accent">*</span></label>
            <textarea name="message" id="f-message" required aria-required="true" rows="4" placeholder="The repetitive task, the tool you've outgrown, the thing you keep meaning to fix…" class="form-field resize-y leading-[1.5]"></textarea>
            <div class="field-error" data-error-for="message" hidden></div>
          </div>
          <button type="submit" class="submit-btn">Request my consult</button>
          <div class="font-mono text-[11.5px] text-muted text-center mt-[14px]">Your details stay with us. No lists, no spam.</div>
        </form>

        <div id="form-success" hidden style="text-align:center;padding:18px 6px;">
          <div style="width:56px;height:56px;border-radius:999px;background:color-mix(in oklab,var(--accent) 16%, transparent);display:flex;align-items:center;justify-content:center;margin:0 auto 22px;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12.5 L10 17.5 L19 7" stroke="var(--accent)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-serif font-semibold text-[26px] m-0 mb-3">Thanks, <span data-name></span> — we've got it.</h3>
          <p class="text-[16.5px] leading-[1.6] text-muted mx-auto mb-6 max-w-[30em]">We'll reply within one business day to set a time, and we'll come to the call having looked into what you shared. Talk soon.</p>
          <button data-reset class="btn-secondary" style="padding:12px 22px;font-size:15px;">Send another</button>
        </div>
      </div>
    </div>
  </div>
</section>
